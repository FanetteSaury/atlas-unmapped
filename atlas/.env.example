# Atlas — environment variables
# Copy to .env.local for development. Never commit .env.local.
# In production, set these in the Vercel project dashboard.
#
# All of these are OPTIONAL. With zero env vars set, Atlas still runs:
#   - chat returns deterministic stub replies (UI + scoring still work)
#   - Atlas Cards are not persisted (dashboards show seed cohort only)
#   - WhatsApp + voice channels disabled (browser channel still works)
# Add only the keys you have.

# === LLM (recommended — unlocks real Claude orchestrator) ===
# Free credits on signup at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === Voice (optional — Whisper STT for WA voice notes) ===
OPENAI_API_KEY=sk-...

# === Persistence (optional — Vercel KV / Upstash Redis) ===
# Without this, completed Atlas Cards aren't stored. Dashboards still
# render the pre-seeded "first cohort" JSON. Provision via:
#   Vercel dashboard → Storage → Upstash for Redis → free tier
# Then `pnpm dlx vercel env pull .env.local` auto-populates these.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=

# === WhatsApp (Twilio Sandbox, Phase 3) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_FROM=whatsapp:+14155238886
# Salt for SHA-256 phone-number hashing. 32+ random bytes, hex.
# We never store raw E.164 numbers. Rotate per environment.
WA_PHONE_SALT=change-me-to-32-bytes-random-hex

# === WA Squad invite links (per country × ISCO) ===
# Created manually by Fanette in WhatsApp on her phone, copied here.
# See docs/SETUP_TWILIO.md steps 8-10. Never commit real values.
WA_GROUP_GH_7421=
WA_GROUP_GH_7531=
WA_GROUP_GH_2519=
WA_GROUP_GH_5223=
WA_GROUP_BD_7531=
WA_GROUP_BD_7421=

# === LLM model override (optional) ===
# Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=

# === Atlas Card signing ===
# HMAC key for signing the share-URL slug. Rotate per environment.
ATLAS_CARD_SIGNING_SECRET=change-me-to-a-32-byte-random-hex

# === Default country for the demo ===
NEXT_PUBLIC_DEFAULT_COUNTRY=GH
