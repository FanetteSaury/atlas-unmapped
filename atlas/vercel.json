{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 30,
      "excludeFiles": "{node_modules/**,.next/**,public/_legacy/**,scripts/**,tests/**,data/lmic/_raw/**,**/*.md,**/*.pdf,**/*.xlsx,**/*.zip,**/*.rds}"
    }
  }
}
