# Atlas — Hack-Nation 2026 — repo-root .gitignore
# (atlas/ has its own Next.js .gitignore; this covers repo-level concerns)

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Env files (anywhere)
.env
.env.local
.env.*.local
*.env

# Build artifacts in atlas/
atlas/.next/
atlas/out/
atlas/.vercel/
atlas/node_modules/
atlas/.turbo/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/
*.lcov

# Prisma generated client (regenerated by postinstall)
atlas/src/generated/

# Local backups
*.bak
*.tmp

# Python
atlas/.venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# LMIC raw downloads — ignore the heavy binary blobs, keep small text + report
atlas/data/lmic/_raw/*.xlsx
atlas/data/lmic/_raw/*.zip
atlas/data/lmic/_raw/*.rds
atlas/data/lmic/_raw/*.pdf
# (CSV + JSON < 1MB are kept for grep-ability and citation)
*.zip
*.mp4
use-this-*.html
